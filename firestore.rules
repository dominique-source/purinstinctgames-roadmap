rules_version = '2';

// Model: anyone can read (investors/partners viewing the map). Editing
// requires the shared passcode, checked once against config/access and
// remembered as a sessions/{uid} doc tied to that visitor's anonymous-auth
// uid (persists across reloads on the same device/browser).
service cloud.firestore {
  match /databases/{database}/documents {
    function isUnlocked() {
      return request.auth != null
        && exists(/databases/$(database)/documents/sessions/$(request.auth.uid));
    }

    // Holds the passcode hash. Never directly readable/writable by clients —
    // only referenced internally via get() from the sessions rule below.
    match /config/access {
      allow read, write: if false;
    }

    match /sessions/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.passcodeHash ==
           get(/databases/$(database)/documents/config/access).data.passcodeHash;
      allow update, delete: if false;
    }

    match /tasks/{taskId} {
      allow read: if true;
      allow write: if isUnlocked();
    }

    // User-added milestones ("onglets") and tasks, layered on top of the
    // fixed M1-M12 plan defined in lib/roadmap.ts.
    match /customMilestones/{id} {
      allow read: if true;
      allow create, update, delete: if isUnlocked();
    }

    match /customTasks/{id} {
      allow read: if true;
      allow create, update, delete: if isUnlocked();
    }

    // User-added checkpoint criteria, layered on top of the fixed C1-C4
    // criteria defined in lib/roadmap.ts.
    match /customCriteria/{id} {
      allow read: if true;
      allow create, update, delete: if isUnlocked();
    }

    // Overlay for editing/soft-deleting a task from the fixed M1-M12 plan
    // without touching lib/roadmap.ts. Doc id == the static task id.
    match /taskEdits/{id} {
      allow read: if true;
      allow create, update, delete: if isUnlocked();
    }

    // Overlay for soft-deleting a milestone from the fixed M1-M12 plan.
    // Doc id == the static milestone id.
    match /milestoneEdits/{id} {
      allow read: if true;
      allow create, update, delete: if isUnlocked();
    }

    // Overlay for soft-deleting a criterion from the fixed C1-C4 checkpoints.
    // Doc id == the static criterion id.
    match /criterionEdits/{id} {
      allow read: if true;
      allow create, update, delete: if isUnlocked();
    }

    // Overlay for soft-deleting an entire phase (with its milestones and
    // checkpoint). Doc id == the static phase id.
    match /phaseEdits/{id} {
      allow read: if true;
      allow create, update, delete: if isUnlocked();
    }

    // Today's focus: exactly 3 slots per day. Doc id == `${date}_${slot}`,
    // so the slot count is capped structurally rather than by a rule.
    match /focusSlots/{id} {
      allow read: if true;
      allow create, update, delete: if isUnlocked();
    }

    // Free-form "what derailed me today" list, no cap.
    match /derailedTasks/{id} {
      allow read: if true;
      allow create, update, delete: if isUnlocked();
    }

    // Named contacts attached to a task (e.g. a "Contact investors" task
    // holding a long list of individual outreach statuses), so a task with
    // 100 people doesn't turn into 100 milestone tasks.
    match /contacts/{id} {
      allow read: if true;
      allow create, update, delete: if isUnlocked();
    }

    // Append-only audit log — never edited or deleted once written.
    match /history/{entryId} {
      allow read: if true;
      allow create: if isUnlocked();
      allow update, delete: if false;
    }
  }
}
